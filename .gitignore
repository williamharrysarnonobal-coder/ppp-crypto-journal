# Local bot scripts — contain hardcoded Telegram + Supabase secrets,
# never push these to GitHub.
btc_live_bot.py
crypto_live_bot.py
economic_calendar_bot.py
screener_bot.py
*.env

# The bots write their own console output here when run with a redirect
# (e.g. `python btc_live_bot.py > bot.log`) — local runtime noise, not code.
*.log

# Python bytecode cache
__pycache__/
*.pyc

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
